// Object : Object is a real instance of class

// Syntax :

// ClassName objectName = new ClassName();

class Car {

    String brand = "Toyota";

    public static void main(String[] args) {

        // Object Creation

        Car c = new Car();

        // c is object

        System.out.println(c.brand);

    }
}
