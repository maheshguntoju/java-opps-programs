// Class : Class is a blueprint/template in Java

class Car {

    String brand = "Toyota";

    // Method
    void display() {

        System.out.println("Brand : " + brand);

    }

    public static void main(String[] args) {

        // Object : Object is a real instance of class

        // Syntax :
        // ClassName objectName = new ClassName();

        Car c = new Car();

        // c is object

        c.display();

    }
}


